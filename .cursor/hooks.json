{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/shell-safety.js",
        "timeout": 10,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/guard-critical-patterns.js",
        "timeout": 10,
        "failClosed": false
      }
    ]
  }
}
