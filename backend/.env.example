# Plantilla de variables para el backend (copiar a `.env` en esta carpeta; no commitear secretos).
# Documentación: SHARED_CONTEXT.md apartado 2.1 (desarrollo local).

# --- PostgreSQL (recomendado para desarrollo con reservas, clientes, SSR/IA) ---
# Sin DATABASE_URL el motor queda en Firestore legacy y `pool` es null → muchas rutas no operan.
# DB_MODE=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# --- Node ---
# NODE_ENV=development

# --- API pública IA (ChatGPT / Actions) — endurecer respuestas para GPT Store o clientes finales ---
# Por defecto desactivado: las respuestas conservan telemetría útil para QA (payload_version, diagnósticos, etc.).
# Con 1: se eliminan del JSON campos técnicos, errores de correo detallados, candidatos de catalog_id, etc.
# PUBLIC_AI_SANITIZE_RESPONSES=1
# (sinónimo) PUBLIC_AI_PUBLIC_MODE=1

# --- Email (local) ---
# Opción 1: Resend (recomendado en staging/producción)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=reservas@tu-dominio.com
#
# Opción 2: Gmail SMTP (útil en local con App Password)
# EMAIL_USER=tu_cuenta@gmail.com
# EMAIL_PASS=tu_app_password_de_16_caracteres
# EMAIL_FROM=tu_cuenta@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
#
# Nota: EMAIL_PASS no es tu contraseña normal; debe ser App Password de Google.

# (Resto: Firebase, JWT, MercadoPago, etc. según tu entorno; no duplicar aquí valores sensibles.)
