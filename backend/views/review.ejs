<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tu opinión sobre <%= resena.propiedad_nombre || resena.empresa_nombre %></title>
    <link rel="stylesheet" href="/public/css/website.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="font-sans bg-gray-50 py-8 px-4">

<div class="max-w-[600px] mx-auto bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.08)] overflow-hidden">

    <!-- ENCABEZADO -->
    <div class="px-8 pt-7 pb-5 border-b border-gray-100 text-center">
        <% if (resena.logo_url) { %>
            <img src="<%= resena.logo_url %>" alt="<%= resena.empresa_nombre %>" class="h-12 mx-auto mb-3 object-contain">
        <% } %>
        <h1 class="text-xl font-bold text-gray-900"><%= resena.empresa_nombre %></h1>
        <% if (resena.propiedad_nombre) { %>
            <p class="text-gray-500 mt-1">Opinión sobre <strong><%= resena.propiedad_nombre %></strong></p>
        <% } %>
        <% if (resena.nombre_huesped) { %>
            <p class="text-sm text-gray-400 mt-1">Hola, <strong><%= resena.nombre_huesped %></strong> 👋</p>
        <% } %>
    </div>

    <!-- PASO 1: FORMULARIO -->
    <div id="step-1" class="px-8 py-7">

        <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-4">Calificación general</p>
        <div class="review-star-group review-star-lg mb-6" id="stars-general">
            <% for (let i = 5; i >= 1; i--) { %>
            <input type="radio" name="punt_general" id="g<%= i %>" value="<%= i %>">
            <label for="g<%= i %>">★</label>
            <% } %>
        </div>

        <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-4">Detalles de tu estadía</p>
        <div class="mb-6">
            <% const cats = [
                { key: 'punt_limpieza',     icon: '🧹', label: 'Limpieza' },
                { key: 'punt_ubicacion',    icon: '📍', label: 'Ubicación' },
                { key: 'punt_llegada',      icon: '🛎️', label: 'Llegada / Check-in' },
                { key: 'punt_comunicacion', icon: '💬', label: 'Comunicación' },
                { key: 'punt_equipamiento', icon: '🏡', label: 'Equipamiento' },
                { key: 'punt_valor',        icon: '💲', label: 'Relación calidad/precio' }
            ]; %>
            <% cats.forEach(function(cat) { %>
            <div class="flex items-center justify-between py-2.5 border-b border-gray-50 last:border-b-0">
                <span class="text-[0.95rem] text-gray-700 flex items-center gap-2"><%= cat.icon %> <%= cat.label %></span>
                <div class="review-star-group review-star-sm">
                    <% for (let i = 5; i >= 1; i--) { %>
                    <input type="radio" name="<%= cat.key %>" id="<%= cat.key %>_<%= i %>" value="<%= i %>">
                    <label for="<%= cat.key %>_<%= i %>">★</label>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>

        <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-4">Tu experiencia en palabras</p>
        <div class="space-y-3 mb-6">
            <textarea id="texto-positivo" class="form-input rounded-lg py-3 text-[0.95rem] resize-y" rows="3" placeholder="¿Qué fue lo mejor de tu estadía?"></textarea>
            <textarea id="texto-negativo" class="form-input rounded-lg py-3 text-[0.95rem] resize-y" rows="2" placeholder="¿Hay algo que podríamos mejorar? (opcional)"></textarea>
        </div>

        <p id="error-msg" class="text-danger-500 text-sm mt-2 hidden">Por favor, selecciona al menos la calificación general (★).</p>
        <button type="button" class="btn w-full rounded-xl py-3.5 text-base font-semibold normal-case shadow-md hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed" id="btn-enviar"<% if (resena.primary_color) { %> style="background-color: <%= resena.primary_color %>; border-color: transparent;"<% } %>>Enviar mi opinión →</button>
    </div>

    <!-- PASO 2: GRACIAS + GOOGLE -->
    <div id="step-2" class="hidden px-8 py-10 text-center">
        <div class="w-16 h-16 rounded-full bg-success-100 flex items-center justify-center mx-auto mb-5 text-success-600">
            <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">¡Muchas gracias!</h2>
        <p class="text-gray-500 mt-2">Tu opinión ha sido registrada y nos ayuda a seguir mejorando.</p>

        <% if (resena.google_maps_url) { %>
        <p class="text-gray-600 mt-6 font-medium">Un último paso (opcional):</p>
        <p class="text-gray-500 text-sm mt-1">Ayúdanos a llegar a más viajeros compartiendo tu experiencia en Google.</p>
        <a href="<%= resena.google_maps_url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 py-3.5 px-7 rounded-xl border-2 border-gray-200 bg-white text-base font-semibold text-gray-700 cursor-pointer no-underline transition hover:border-gray-300 hover:shadow-md mt-5" id="btn-google">
            <img src="https://www.google.com/favicon.ico" alt="Google" class="w-5 h-5">
            Dejar reseña en Google Maps
        </a>
        <% } %>

        <a href="/" class="block mt-3.5 text-sm text-gray-400 no-underline hover:text-gray-500">Volver al inicio →</a>
    </div>

</div>

<script>
    const TOKEN = '<%= resena.token %>';

    document.getElementById('btn-enviar').addEventListener('click', async () => {
        const general = document.querySelector('input[name="punt_general"]:checked');
        const errorMsg = document.getElementById('error-msg');

        if (!general) {
            errorMsg.classList.remove('hidden');
            return;
        }
        errorMsg.classList.add('hidden');

        const btn = document.getElementById('btn-enviar');
        btn.disabled = true;
        btn.textContent = 'Enviando...';

        const datos = {
            punt_general:     parseInt(general.value),
            punt_limpieza:    parseInt(document.querySelector('input[name="punt_limpieza"]:checked')?.value || 0) || null,
            punt_ubicacion:   parseInt(document.querySelector('input[name="punt_ubicacion"]:checked')?.value || 0) || null,
            punt_llegada:     parseInt(document.querySelector('input[name="punt_llegada"]:checked')?.value || 0) || null,
            punt_comunicacion:parseInt(document.querySelector('input[name="punt_comunicacion"]:checked')?.value || 0) || null,
            punt_equipamiento:parseInt(document.querySelector('input[name="punt_equipamiento"]:checked')?.value || 0) || null,
            punt_valor:       parseInt(document.querySelector('input[name="punt_valor"]:checked')?.value || 0) || null,
            texto_positivo:   document.getElementById('texto-positivo').value.trim() || null,
            texto_negativo:   document.getElementById('texto-negativo').value.trim() || null,
        };

        try {
            const res = await fetch(`/api/resenas/submit/${TOKEN}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            if (!res.ok) throw new Error('Error al guardar');

            document.getElementById('step-1').classList.add('hidden');
            document.getElementById('step-2').classList.remove('hidden');
        } catch (e) {
            btn.disabled = false;
            btn.textContent = 'Enviar mi opinión →';
            errorMsg.textContent = 'Hubo un error al enviar tu opinión. Por favor intenta nuevamente.';
            errorMsg.classList.remove('hidden');
        }
    });

    const btnGoogle = document.getElementById('btn-google');
    if (btnGoogle) {
        btnGoogle.addEventListener('click', () => {
            fetch(`/api/resenas/google-click/${TOKEN}`, { method: 'POST' }).catch(() => {});
        });
    }
</script>
</body>
</html>
