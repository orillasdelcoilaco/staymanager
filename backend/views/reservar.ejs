<%- /* backend/views/reservar.ejs */ %>
<!DOCTYPE html>
<html lang="<%= htmlLang || 'es' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/website.css">
    <%- include('partials/web-fonts') %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .sm-modal-reglas { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:65; align-items:center; justify-content:center; padding:1rem; }
        .sm-modal-reglas.open { display:flex; }
    </style>
    
    <%# Funciones auxiliares para formato %>
    <%
        const formatCurrency = (value) => `$${(Math.round(value) || 0).toLocaleString('es-CL')}`;
        const formatDateDisplay = (dateString) => {
            if (!dateString) return 'N/A';
            try {
                const date = new Date(dateString + 'T00:00:00Z'); // Asumir UTC para parsear yyyy-MM-dd
                return date.toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
            } catch (e) {
                return dateString;
            }
        };
        const precioFinalNum = parseFloat(query.precioFinal) || 0;
        const dep = depositoReserva || {};
        const abonoNum = Number(dep.montoDeposito || 0);
        const saldoNum = Number(dep.saldo || Math.max(0, precioFinalNum - abonoNum));
        const depActivo = dep.activo !== false;
        const depNota = String(empresa.websiteSettings?.booking?.depositoNotaHtml || '').trim();
        const garantiaModo = String(empresa.websiteSettings?.booking?.garantiaModo || 'abono_manual');
        const garantiaDetalleOperacion = String(empresa.websiteSettings?.booking?.garantiaDetalleOperacion || '').trim();
        const garantiaTexto = garantiaModo === 'sin_garantia'
            ? 'Sin garantía previa para confirmar la reserva.'
            : (garantiaModo === 'preautorizacion_externa'
                ? 'Garantía por preautorización externa (sin integración de pasarela en StayManager).'
                : 'Garantía mediante abono manual registrado por operación.');
        const depEtiqueta = dep.tipo === 'monto_fijo'
            ? 'Abono para reservar (monto fijo):'
            : `Abono para reservar (${Number(dep.porcentaje || 10)}%):`;
    %>
</head>
<body class="bg-gray-50">

    <%- include('partials/header') %>

    <main class="container py-12">
        <div class="max-w-6xl mx-auto">
            
            <h1 class="text-3xl font-bold text-gray-900 mb-8">Completa tu Reserva</h1>

            <%# --- MODIFICADO: Layout de 2 columnas para Resumen y Formulario --- %>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

                <%# --- COLUMNA IZQUIERDA: Resumen y Mosaico --- %>
                <div class="space-y-8">
                    <% if (isGroup) { %>
                        <%# --- LÓGICA PARA GRUPO --- %>
                        <div>
                            <h2 class="text-2xl font-semibold text-gray-800 mb-4">Resumen de tu Grupo</h2>
                            
                            <div class="bg-white p-6 rounded-lg shadow-lg border border-gray-200">
                                <div class="space-y-3">
                                    <div class="flex justify-between items-center">
                                        <span class="text-gray-600">Fechas:</span>
                                        <span class="font-semibold text-gray-900"><%= formatDateDisplay(query.fechaLlegada) %> - <%= formatDateDisplay(query.fechaSalida) %></span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-gray-600">Noches:</span>
                                        <span class="font-semibold text-gray-900"><%= query.noches %></span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-gray-600">Huéspedes:</span>
                                        <span class="font-semibold text-gray-900"><%= query.personas %></span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-gray-600">Propiedades:</span>
                                        <span class="font-semibold text-gray-900"><%= propiedad.length %></span>
                                    </div>
                                    
                                    <div class="border-t pt-4 mt-4">
                                        <div class="flex justify-between items-center text-xl font-bold">
                                            <span>Total Estadía:</span>
                                            <span><%= formatCurrency(precioFinalNum) %></span>
                                        </div>
                                        <% if (depActivo) { %>
                                            <div class="flex justify-between items-center text-base font-semibold text-primary-600 mt-1">
                                                <span><%= depEtiqueta %></span>
                                                <span><%= formatCurrency(abonoNum) %></span>
                                            </div>
                                            <div class="flex justify-between items-center text-sm text-gray-600 mt-1">
                                                <span>Saldo al llegar:</span>
                                                <span><%= formatCurrency(saldoNum) %></span>
                                            </div>
                                        <% } else { %>
                                            <div class="text-sm text-success-700 mt-2">
                                                Esta empresa no requiere abono previo para reservar.
                                            </div>
                                        <% } %>
                                        <% if (depNota) { %>
                                            <p class="text-xs text-gray-600 mt-3"><%= depNota %></p>
                                        <% } %>
                                        <p class="text-xs text-gray-600 mt-2"><strong>Política de garantía:</strong> <%= garantiaTexto %></p>
                                        <% if (garantiaDetalleOperacion) { %>
                                            <p class="text-xs text-gray-500 mt-1"><%= garantiaDetalleOperacion %></p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div>
                            <h3 class="text-xl font-semibold text-gray-800 mb-3">Propiedades Incluidas</h3>
                            <%# Mosaico de Imágenes %>
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                                <% propiedad.forEach(p => { %>
                                    <% const imgUrl = p.websiteData?.cardImage?.storagePath || 'https://via.placeholder.com/150x100.png?text=Sin+Imagen'; %>
                                    <div class="relative rounded-lg overflow-hidden aspect-w-1 aspect-h-1 bg-gray-100">
                                        <img src="<%= imgUrl %>" alt="<%= p.nombre %>" class="w-full h-full object-cover">
                                        <div class="absolute bottom-0 left-0 right-0 p-2 bg-gradient-to-t from-black/60 to-transparent">
                                            <p class="text-white text-xs font-semibold truncate"><%= p.nombre %></p>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>

                    <% } else { %>
                        <%# --- LÓGICA PARA PROPIEDAD INDIVIDUAL (EXISTENTE) --- %>
                        <%
                            const imgUrl = propiedad.websiteData?.cardImage?.storagePath || 'https://via.placeholder.com/400x300.png?text=Sin+Imagen';
                        %>
                        <div>
                            <h2 class="text-2xl font-semibold text-gray-800 mb-4">Tu Estadía en: <%= propiedad.nombre %></h2>
                            
                            <div class="bg-white rounded-lg shadow-lg overflow-hidden border border-gray-200">
                                <img src="<%= imgUrl %>" alt="<%= propiedad.nombre %>" class="w-full h-48 object-cover">
                                <div class="p-6">
                                    <div class="space-y-3">
                                        <div class="flex justify-between items-center">
                                            <span class="text-gray-600">Fechas:</span>
                                            <span class="font-semibold text-gray-900"><%= formatDateDisplay(query.fechaLlegada) %> - <%= formatDateDisplay(query.fechaSalida) %></span>
                                        </div>
                                        <div class="flex justify-between items-center">
                                            <span class="text-gray-600">Noches:</span>
                                            <span class="font-semibold text-gray-900"><%= query.noches %></span>
                                        </div>
                                        <div class="flex justify-between items-center">
                                            <span class="text-gray-600">Huéspedes:</span>
                                            <span class="font-semibold text-gray-900"><%= query.personas %></span>
                                        </div>
                                        
                                        <div class="border-t pt-4 mt-4">
                                            <div class="flex justify-between items-center text-xl font-bold">
                                                <span>Total Estadía:</span>
                                                <span><%= formatCurrency(precioFinalNum) %></span>
                                            </div>
                                            <% if (depActivo) { %>
                                                <div class="flex justify-between items-center text-base font-semibold text-primary-600 mt-1">
                                                    <span><%= depEtiqueta %></span>
                                                    <span><%= formatCurrency(abonoNum) %></span>
                                                </div>
                                                <div class="flex justify-between items-center text-sm text-gray-600 mt-1">
                                                    <span>Saldo al llegar:</span>
                                                    <span><%= formatCurrency(saldoNum) %></span>
                                                </div>
                                            <% } else { %>
                                                <div class="text-sm text-success-700 mt-2">
                                                    Esta empresa no requiere abono previo para reservar.
                                                </div>
                                            <% } %>
                                            <% if (depNota) { %>
                                                <p class="text-xs text-gray-600 mt-3"><%= depNota %></p>
                                            <% } %>
                                            <p class="text-xs text-gray-600 mt-2"><strong>Política de garantía:</strong> <%= garantiaTexto %></p>
                                            <% if (garantiaDetalleOperacion) { %>
                                                <p class="text-xs text-gray-500 mt-1"><%= garantiaDetalleOperacion %></p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>

                <%# --- COLUMNA DERECHA: Formulario --- %>
                <div class="bg-white p-6 md:p-8 rounded-lg shadow-lg border border-gray-200">
                    <h2 class="text-2xl font-semibold text-gray-800 mb-6">Datos del Huésped Principal</h2>
                    
                    <form id="checkout-form" class="space-y-4">
                        <div>
                            <label for="nombre" class="form-label">Nombre Completo</label>
                            <input type="text" id="nombre" name="nombre" class="form-input" required>
                        </div>
                        <div>
                            <label for="email" class="form-label">Email</label>
                            <input type="email" id="email" name="email" class="form-input" required>
                        </div>
                        <div>
                            <label for="telefono" class="form-label">Teléfono (Ej: +56912345678)</label>
                            <input
                                type="tel"
                                id="telefono"
                                name="telefono"
                                class="form-input"
                                placeholder="+56912345678"
                                inputmode="tel"
                                autocomplete="tel"
                                required
                            >
                        </div>
                         <div>
                            <label for="rut" class="form-label">RUT (Sin puntos, con guión. Ej: 12345678-9)</label>
                            <input
                                type="text"
                                id="rut"
                                name="rut"
                                class="form-input"
                                placeholder="12345678-9"
                                inputmode="text"
                                autocomplete="off"
                            >
                        </div>
                        <div>
                            <label for="comentarios" class="form-label">Comentarios (Opcional)</label>
                            <textarea id="comentarios" name="comentarios" rows="3" class="form-input" placeholder="¿Necesitas algo especial? ¿Hora de llegada?"></textarea>
                        </div>
                        
                        <div class="pt-4">
                            <button type="submit" id="submit-button" class="btn w-full text-lg">
                                <span>
                                    <%= depActivo ? `Confirmar y Pagar Abono (${formatCurrency(abonoNum)})` : 'Confirmar Reserva' %>
                                </span>
                                <span id="loading-spinner" class="hidden">
                                    <i class="fas fa-spinner fa-spin"></i> Procesando...
                                </span>
                            </button>
                        </div>
                    </form>
                    <div id="error-message" class="mt-4 text-center text-danger-600 font-medium hidden"></div>
                </div>

            </div>

            <% if (locals.reglasVista) { %>
            <%
                const _checkinR  = empresa.horaCheckIn  || empresa.websiteSettings?.normas?.checkin  || '15:00';
                const _checkoutR = empresa.horaCheckOut || empresa.websiteSettings?.normas?.checkout || '11:00';
                const _propRules = isGroup ? propiedad[0] : propiedad;
                const _dispInR = (reglasVista.horaEntrada24) ? reglasVista.horaEntrada24 : _checkinR;
                const _dispOutR = (reglasVista.horaSalida24) ? reglasVista.horaSalida24 : _checkoutR;
                const _dispMaxR = (reglasVista.maxHuespedesUI > 0) ? reglasVista.maxHuespedesUI : (_propRules.capacidad || 0);
            %>
            <div class="mt-10 pt-8 border-t border-gray-200">
                <h2 class="text-lg font-bold text-gray-900 mb-2">Normas del alojamiento</h2>
                <p class="text-sm text-gray-600 mb-4">Revisa horarios y normas antes de confirmar tu reserva.</p>
                <div class="bg-white p-5 rounded-lg border border-gray-200 max-w-xl">
                    <h3 class="font-semibold text-gray-800 mb-3 text-sm">Normas de la casa</h3>
                    <ul class="space-y-2 text-sm text-gray-600">
                        <li class="flex items-start gap-2"><i class="fas fa-clock w-4 text-gray-400 mt-0.5"></i><span>Llegada: desde las <%= _dispInR %></span></li>
                        <li class="flex items-start gap-2"><i class="fas fa-clock w-4 text-gray-400 mt-0.5"></i><span>Salida: antes de las <%= _dispOutR %></span></li>
                        <li class="flex items-start gap-2"><i class="fas fa-users w-4 text-gray-400 mt-0.5"></i><span>Máx. <%= _dispMaxR %> huéspedes</span></li>
                        <li class="flex items-start gap-2 pt-0.5">
                            <span class="w-4 flex-shrink-0" aria-hidden="true"></span>
                            <button type="button"
                                    class="text-primary-600 underline font-medium hover:text-primary-700 bg-transparent border-0 p-0 cursor-pointer text-left text-sm"
                                    onclick="document.getElementById('modal-reglas-casa').classList.add('open'); document.body.classList.add('overflow-hidden');">
                                Más información
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
            <% } %>

        </div>
    </main>

    <%- include('partials/property-house-rules') %>

    <%- include('partials/footer') %>

    <script>
        // Pasar datos de EJS a JavaScript para el checkout
        window.checkoutData = {
            // Convertir 'propiedad' (que es un array si isGroup, o un objeto si no)
            // al formato que espera checkout.js (un string de IDs separados por coma)
            propiedadId: '<%= isGroup ? propiedad.map(p => p.id).join(',') : propiedad.id %>',
            fechaLlegada: '<%= query.fechaLlegada %>',
            fechaSalida: '<%= query.fechaSalida %>',
            noches: parseInt('<%= query.noches %>') || 0,
            precioFinal: parseFloat('<%= query.precioFinal %>') || 0,
            personas: parseInt('<%= query.personas %>') || 0,
            abono: parseFloat('<%= abonoNum %>') || 0,
            depositoActivo: <%= depActivo ? 'true' : 'false' %>
        };
    </script>
    <script src="/public/js/website-i18n.js"></script>
    <script src="/public/js/checkout.js"></script>

</body>
</html>