<%# backend/views/partials/property-card.ejs %>
<%
    const _img      = prop.websiteData?.cardImage?.storagePath || 'https://placehold.co/400x400/e5e7eb/9ca3af?text=Sin+imagen';
    const _alt      = prop.websiteData?.cardImage?.altText || prop.nombre;
    const _tiene    = isSearchResult && prop.pricing && prop.pricing.totalPriceCLP > 0;
    const _pxnExact = _tiene && prop.pricing.nights > 0 ? Math.round(prop.pricing.totalPriceCLP / prop.pricing.nights) : 0;
    const _pxnBase  = prop.precioBaseNoche > 0 ? prop.precioBaseNoche : 0;
    const _pxn      = _pxnExact > 0 ? _pxnExact : _pxnBase;
    const _esBase   = !_tiene && _pxnBase > 0;
    const _fmtCLP   = (v) => `$${Math.round(v || 0).toLocaleString('es-CL')}`;
    const _link     = `/propiedad/${prop.id}?fechaLlegada=${query.fechaLlegada||''}&fechaSalida=${query.fechaSalida||''}&personas=${query.personas||''}`;
    const _dorm     = prop.numPiezas ? `${prop.numPiezas} dorm.` : '';
    const _banos    = prop.numBanos  ? `${prop.numBanos} baños`  : '';
    const _detalles = [_dorm, _banos, `${prop.capacidad} pers.`].filter(Boolean).join(' · ');
%>
<a href="<%= _link %>" class="group block focus:outline-none">
    <div class="relative overflow-hidden rounded-xl bg-gray-100" style="aspect-ratio:1/1">
        <img src="<%= _img %>" alt="<%= _alt %>" loading="lazy"
             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
        <% if (_tiene) { %>
        <span class="absolute top-3 left-3 bg-white/95 text-success-700 text-xs font-bold px-2.5 py-1 rounded-full shadow-sm backdrop-blur-sm">
            ✓ Disponible
        </span>
        <% } %>
    </div>
    <div class="mt-3 px-0.5">
        <h3 class="font-semibold text-gray-900 text-sm leading-snug line-clamp-1"><%= prop.nombre %></h3>
        <p class="text-xs text-gray-500 mt-0.5"><%= _detalles %></p>
        <p class="mt-1.5 text-sm font-bold text-gray-900">
            <% if (_tiene && _pxnExact > 0) { %>
                <%= _fmtCLP(_pxnExact) %> <span class="font-normal text-gray-500">/ noche</span>
            <% } else if (_esBase) { %>
                <span class="font-normal text-gray-400 text-xs">desde</span> <%= _fmtCLP(_pxnBase) %> <span class="font-normal text-gray-500">/ noche</span>
            <% } else { %>
                <span class="font-normal text-gray-500 text-xs">Consultar disponibilidad</span>
            <% } %>
        </p>
    </div>
</a>
