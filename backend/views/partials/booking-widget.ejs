<%# backend/views/partials/booking-widget.ejs — conversion-focused, compatible con booking.js %>
<%
    const _wFmt     = (v) => `$${Math.round(v||0).toLocaleString('es-CL')}`;
    const _wRating  = (typeof _rating !== 'undefined') ? _rating : null;
    const _wResenas = (typeof _nResenas !== 'undefined') ? _nResenas : 0;
    const _wTotal   = defaultPriceData?.totalPriceCLP || 0;
    const _wNoches  = defaultPriceData?.nights || 0;
    const _wAbono   = _wTotal > 0 ? Math.round(_wTotal * 0.10) : 0;
    const _wNoche   = (_wTotal > 0 && _wNoches > 0) ? Math.round(_wTotal / _wNoches) : (typeof _precioNoche !== 'undefined' ? _precioNoche : 0);
    const _wIsWknd  = (typeof isDefaultWeekend !== 'undefined') ? isDefaultWeekend : false;
    const _minNochesW = (typeof minNochesSSR === 'number' && minNochesSSR >= 1)
        ? minNochesSSR
        : Math.max(1, parseInt(String(empresa?.websiteSettings?.booking?.minNoches ?? propiedad?.websiteData?.booking?.minNoches ?? '1'), 10) || 1);
    const wConfig   = { propiedadId: propiedad.id, defaultPrice: defaultPriceData || null, minNoches: _minNochesW };
%>

<div id="booking-widget-container"
     class="bg-white rounded-2xl border border-gray-200 shadow-[0_8px_30px_rgba(79,70,229,0.15)] overflow-hidden"
     data-booking-config='<%= JSON.stringify(wConfig) %>'>

    <%# ── HERO: abono como protagonista ── %>
    <div class="bg-gradient-to-br from-primary-600 to-primary-700 px-6 pt-5 pb-5 text-white">
        <div class="flex items-start justify-between gap-2">
            <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-primary-200 mb-1">Reserva por solo</p>
                <div id="hero-abono" class="flex items-baseline gap-1.5">
                    <% if (_wAbono > 0) { %>
                    <span id="hero-abono-amount" class="text-4xl font-extrabold leading-none tracking-tight"><%= _wFmt(_wAbono) %></span>
                    <% } else { %>
                    <span id="hero-abono-amount" class="text-2xl font-bold leading-none opacity-80">Elige fechas</span>
                    <% } %>
                </div>
                <p class="text-xs text-primary-200 mt-1.5">de abono para confirmar tu estadía</p>
            </div>
            <% if (_wRating) { %>
            <div class="text-right flex-shrink-0 bg-white/15 rounded-xl px-3 py-2">
                <p class="text-sm font-extrabold leading-none"><i class="fas fa-star text-warning-300 text-xs mr-0.5"></i><%= _wRating %></p>
                <p class="text-xs text-primary-200 mt-0.5"><%= _wResenas %> reseña<%= _wResenas !== 1 ? 's' : '' %></p>
            </div>
            <% } %>
        </div>

        <%# Badge fin de semana ── oculto por JS al cambiar fechas %>
        <% if (_wIsWknd && _wAbono > 0) { %>
        <div id="weekend-hint" class="mt-3 inline-flex items-center gap-1.5 bg-white/20 text-white text-xs font-medium px-2.5 py-1 rounded-full">
            <i class="fas fa-calendar-week text-xs"></i>
            Estimado: próximo fin de semana
        </div>
        <% } %>
    </div>

    <%# ── Formulario ── %>
    <form id="booking-form" class="px-5 pt-4 pb-4 space-y-3">
        <input type="hidden" name="propiedadId" value="<%= propiedad.id %>">

        <%# Fechas editables en widget + sincronizadas con calendario bajo el mapa %>
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-gray-50 px-3 py-3">
            <div class="grid grid-cols-2 gap-2">
                <div class="rounded-lg border border-gray-200 bg-white px-3 py-2">
                    <label for="fechaLlegada" class="block text-[10px] font-black text-gray-500 uppercase tracking-wider mb-0.5">Llegada</label>
                    <input type="date" name="fechaLlegada" id="fechaLlegada" required
                           value="<%= prefill.fechaLlegada %>"
                           class="w-full text-sm font-semibold text-gray-900 bg-transparent outline-none">
                </div>
                <div class="rounded-lg border border-gray-200 bg-white px-3 py-2">
                    <label for="fechaSalida" class="block text-[10px] font-black text-gray-500 uppercase tracking-wider mb-0.5">Salida</label>
                    <input type="date" name="fechaSalida" id="fechaSalida" required
                           value="<%= prefill.fechaSalida %>"
                           class="w-full text-sm font-semibold text-gray-900 bg-transparent outline-none">
                </div>
            </div>
            <p class="text-[11px] text-gray-500 mt-2 leading-snug">
                <i class="fas fa-calendar-days text-primary-500 mr-1"></i>
                Puedes ajustar fechas aquí o usar el calendario de disponibilidad de abajo.
            </p>
            <p id="booking-dates-summary" class="text-sm font-semibold text-gray-900 tabular-nums min-h-[1.35rem] mt-1"></p>
            <div class="border-t border-gray-200 mt-2 pt-3">
                <label for="personas" class="block text-[10px] font-black text-gray-500 uppercase tracking-wider mb-0.5">Huéspedes</label>
                <input type="number" name="personas" id="personas" min="1" max="<%= propiedad.capacidad %>" required
                       value="<%= prefill.personas %>"
                       class="w-full text-sm font-medium text-gray-900 bg-transparent outline-none">
            </div>
        </div>

        <%# Loader %>
        <div id="price-loader" class="hidden text-center py-0.5">
            <p class="text-xs text-gray-400 animate-pulse">Calculando precio...</p>
        </div>

        <%# CTA principal %>
        <button type="submit" id="submit-button" <%= _wAbono > 0 ? '' : 'disabled' %>
                class="btn w-full rounded-xl py-4 text-base font-extrabold uppercase tracking-wide
                       disabled:opacity-40 disabled:cursor-not-allowed transition-all
                       shadow-[0_4px_14px_rgba(79,70,229,0.4)] hover:shadow-[0_6px_20px_rgba(79,70,229,0.5)]
                       hover:-translate-y-0.5 active:translate-y-0">
            <i class="fas fa-lock text-sm mr-2 opacity-80"></i>Reservar ahora
        </button>

        <%# Precio total — secundario, debajo del botón %>
        <div id="price-display" class="<%= _wTotal > 0 ? '' : 'hidden' %>">
            <div id="deposit-info" class="text-center text-xs text-gray-400">
                <% if (_wTotal > 0) { %>
                Total estadía: <span id="price-total-display" class="font-semibold text-gray-600"><%= _wFmt(_wTotal) %></span>
                <span id="price-label-display" class="text-gray-400">(<%= _wNoches %> noche<%= _wNoches !== 1 ? 's' : '' %>)</span>
                <% } %>
            </div>
        </div>
    </form>

    <%# ── Desglose (noches, referencia USD si aplica, saldo 90%, abono 10%) ── %>
    <div id="price-breakdown" class="mx-5 mb-5 pt-3 border-t border-gray-100 text-xs text-gray-500">
        <p id="price-breakdown-placeholder" class="text-center text-gray-400 <%= _wTotal > 0 ? 'hidden' : '' %>">Selecciona fechas para ver el precio</p>
        <div id="price-breakdown-lines" class="space-y-1.5 <%= _wTotal > 0 ? '' : 'hidden' %>">
            <div class="flex justify-between">
                <span id="price-nights-label">
                    <%= _wNoche > 0 ? _wFmt(_wNoche) : '' %> × <%= _wNoches %> noche<%= _wNoches !== 1 ? 's' : '' %>
                </span>
                <span id="price-nights-value" class="font-medium text-gray-700"><%= _wTotal > 0 ? _wFmt(_wTotal) : '' %></span>
            </div>
            <div id="price-usd-line" class="hidden text-[11px] text-gray-500 leading-snug border-l-2 border-primary-200 pl-2 py-0.5"></div>
            <div class="flex justify-between text-gray-600 pt-1 border-t border-dashed border-gray-200">
                <span>Saldo al llegar (90%)</span>
                <span id="price-resto-value" class="font-medium text-gray-700"><%= _wTotal > 0 ? _wFmt(Math.round(_wTotal * 0.9)) : '' %></span>
            </div>
            <div class="flex justify-between font-semibold text-primary-600 pt-0.5">
                <span>Abono para reservar (10%)</span>
                <span id="price-abono-value"><%= _wTotal > 0 ? _wFmt(_wAbono) : '' %></span>
            </div>
        </div>
    </div>

</div>
